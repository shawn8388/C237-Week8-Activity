<!DOCTYPE html>
<html>
<head>
    <title>Student List App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark p-3">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Student List App</a>
            <a class="nav-link text-white" href="/addStudent">Add new student</a>
        </div>
    </nav>

    <div class="container mt-5">
        <h2 class="text-center mb-4">Students from Student List App Database</h2>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Student Image</th>
                    <th>Dob</th>
                    <th>Contact</th>
                </tr>
            </thead>
            <tbody>
                <% for(let i=0; i < students.length; i++) { %>
                <tr>
                    <td>
                        <a href="/student/<%= students[i].studentId %>">
                            <%= students[i].name %>
                        </a>
                    </td>
                    <td><img src="<%= students[i].image %>" width="50" height="50"></td>
                    <td><%= new Date(students[i].dob).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) %></td>
                    <td><%= students[i].contact %></td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>