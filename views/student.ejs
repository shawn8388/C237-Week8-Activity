<!DOCTYPE html>
<html>
<head>
    <title>Student Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark p-3">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Student List App</a>
            <a class="nav-link text-white" href="/addStudent">Add new student</a>
        </div>
    </nav>

    <div class="container mt-5">
        <h2 class="text-center mb-4">Student Details</h2>
        <% if (student) { %>
            <div style="text-align: center;">
                <p><b>Student Name:</b><br> <%= student.name %></p>
                <p><b>Student Image:</b><br> <img src="<%= student.image %>" width="200"></p>
                <p><b>Date of Birth:</b><br> <%= new Date(student.dob).toLocaleDateString() %></p>
                <p><b>Contact:</b><br> <%= student.contact %></p>
                <a href="/" class="btn btn-secondary">Back to List</a>
            </div>
        <% } else { %>
            <p>No student found.</p>
        <% } %>
    </div>
</body>
</html>